generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @default("")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  stories     Story[]

  @@map("books")
}

model Setting {
  id             Int      @id @default(autoincrement())
  theme          String?  @default("dark")
  geminiApiKey   String?  @map("gemini_api_key")
  groqApiKey     String?  @map("groq_api_key")
  cohereApiKey   String?  @map("cohere_api_key")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("settings")
}

model Character {
  id                  Int      @id @default(autoincrement())
  name                String
  nickname            String?  @default("")
  role                String?  @default("")
  mainObjective       String?  @default("") @map("main_objective")
  fatalFlaw           String?  @default("") @map("fatal_flaw")
  constraints         String?  @default("")
  appearanceAndSkills String?  @default("") @map("appearance_and_skills")
  relationships       Json?    @default("[]")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("characters")
}

model Worldview {
  id               Int      @id @default(autoincrement())
  name             String
  coreTheme        String?  @default("") @map("core_theme")
  systemAndLaws    String?  @default("") @map("system_and_laws")
  absoluteRules    String?  @default("") @map("absolute_rules")
  socialConflicts  String?  @default("") @map("social_conflicts")
  keyLocations     Json?    @default("[]") @map("key_locations")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")
  stories          Story[]

  @@map("worldviews")
}

model Story {
  id            Int        @id @default(autoincrement())
  title         String
  bookId        Int?       @map("book_id")
  book          Book?      @relation(fields: [bookId], references: [id])
  prompt        String?    @default("")
  content       String?    @default("")
  characterIds  Json?      @default("[]") @map("character_ids")
  worldviewId   Int?       @map("worldview_id")
  worldview     Worldview? @relation(fields: [worldviewId], references: [id])
  genre         String?    @default("")
  formatType    String?    @default("") @map("format_type")
  llmProvider   String?    @default("") @map("llm_provider")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @default(now()) @updatedAt @map("updated_at")

  @@map("stories")
}
